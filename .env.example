# ─────────────────────────────────────────────
#  cyber-seed  —  environment configuration
#  Copy to .env and fill in your values:
#  cp .env.example .env
# ─────────────────────────────────────────────

# ── Host user (run `id` to get these) ────────
PUID=1000
PGID=1000

# ── Timezone ─────────────────────────────────
TZ=UTC

# ── Ports ────────────────────────────────────
WEBUI_PORT=8080        # qBittorrent Web UI
TORRENT_PORT=6881      # Torrent traffic (TCP + UDP)

# ── Downloads path on the HOST ───────────────
# Absolute path recommended for production servers
# Default uses a relative ./downloads folder
DOWNLOADS_PATH=./downloads

# ── qBittorrent Web UI credentials ───────────
# These are set in the Web UI on first login.
# Default linuxserver credentials:
#   Username : admin
#   Password : adminadmin   (change immediately!)

# ── rclone / OneDrive settings ───────────────
# Name of the rclone remote you created during setup.sh
# (must match exactly what you typed in `rclone config`)
ONEDRIVE_REMOTE=onedrive

# Target folder path on your OneDrive / SharePoint
# Examples:
#   Personal OneDrive : /Torrents
#   SharePoint        : /sites/MySite/Shared Documents/Torrents
ONEDRIVE_PATH=/Torrents
